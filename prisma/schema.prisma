// Aura — Authentication şeması (Sprint 1)
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  username         String    @unique
  name             String
  passwordHash     String
  role             Role      @default(USER)
  emailVerified    DateTime?
  avatarUrl        String?
  // Brute-force / hesap kilitleme
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?
  // 2FA
  twoFactorSecret  String?
  twoFactorEnabled Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sessions              Session[]
  emailTokens           EmailVerificationToken[]
  passwordResets        PasswordResetToken[]
  posts                 Post[]                    @relation("UserPosts")
  comments              Comment[]                 @relation("UserComments")
  likes                 Like[]                    @relation("UserLikes")
  saves                 SavedPost[]               @relation("UserSaves")
  stories               Story[]                   @relation("UserStories")
  storyViews            StoryView[]               @relation("UserStoryViews")
  following             Follow[]                  @relation("Following")
  followers             Follow[]                  @relation("Followers")
  notificationsReceived Notification[]            @relation("NotificationsReceived")
  notificationsSent     Notification[]            @relation("NotificationsSent")
  conversationLinks     ConversationParticipant[] @relation("UserConversations")
  sentMessages          Message[]                 @relation("UserMessages")
  commentLikes          CommentLike[]             @relation("UserCommentLikes")
  messageReactions      MessageReaction[]         @relation("UserMessageReactions")
  collections           Collection[]              @relation("UserCollections")
  highlights            Highlight[]               @relation("UserHighlights")

  @@index([email])
  @@index([username])
}

// Kalıcı, dönen (rotating) oturumlar = cihaz oturumları
model Session {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Refresh token'ın hash'i saklanır (asla düz metin)
  refreshTokenHash  String    @unique
  // Rotasyon zinciri: yeni oturum bir öncekiyle bağlanır (reuse-detection)
  previousTokenHash String?
  // Cihaz meta verisi
  userAgent         String?
  ipAddress         String?
  deviceLabel       String?
  rememberMe        Boolean   @default(false)
  expiresAt         DateTime
  lastUsedAt        DateTime  @default(now())
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([refreshTokenHash])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
}

// Rate limiting / denetim için giriş denemesi kaydı
model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ipAddress String?
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

/**
 * ===================== Sprint 2 — Feed & Post =====================
 */

enum MediaType {
  image
  video
}

model Post {
  id           String    @id @default(cuid())
  authorId     String
  author       User      @relation("UserPosts", fields: [authorId], references: [id], onDelete: Cascade)
  caption      String
  tags         String[]
  location     String?
  likeCount    Int       @default(0)
  commentCount Int       @default(0)
  createdAt    DateTime  @default(now())
  editedAt     DateTime?
  deletedAt    DateTime?

  media    Media[]
  comments Comment[]
  likes    Like[]
  saves    SavedPost[]

  @@index([createdAt, id])
  @@index([authorId, createdAt])
}

model Media {
  id          String    @id @default(cuid())
  postId      String
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  type        MediaType @default(image)
  url         String
  posterUrl   String?
  width       Int
  height      Int
  blurDataUrl String?
  order       Int       @default(0)

  @@index([postId])
}

model Comment {
  id        String        @id @default(cuid())
  postId    String
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation("UserComments", fields: [authorId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment?      @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[]     @relation("CommentReplies")
  text      String
  likeCount Int           @default(0)
  likes     CommentLike[]
  createdAt DateTime      @default(now())
  deletedAt DateTime?

  @@index([postId, createdAt, id])
}

model CommentLike {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserCommentLikes", fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@index([commentId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserLikes", fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId])
}

model SavedPost {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation("UserSaves", fields: [userId], references: [id], onDelete: Cascade)
  postId       String
  post         Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  // Opsiyonel koleksiyon; koleksiyon silinince kayıt "Tümü"de kalır (SetNull).
  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())

  @@unique([userId, postId])
  @@index([userId, createdAt])
  @@index([collectionId])
}

// Kullanıcının kaydedilenlerini gruplayan isimli koleksiyonlar.
model Collection {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserCollections", fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())

  savedPosts SavedPost[]

  @@unique([userId, name])
  @@index([userId, createdAt])
}

model Story {
  id        String      @id @default(cuid())
  authorId  String
  author    User        @relation("UserStories", fields: [authorId], references: [id], onDelete: Cascade)
  mediaUrl  String
  type      MediaType   @default(image)
  createdAt DateTime    @default(now())
  expiresAt DateTime
  views     StoryView[]

  @@index([expiresAt])
  @@index([authorId, createdAt])
}

model StoryView {
  id       String   @id @default(cuid())
  storyId  String
  story    Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viewerId String
  viewer   User     @relation("UserStoryViews", fields: [viewerId], references: [id], onDelete: Cascade)
  seenAt   DateTime @default(now())

  @@unique([storyId, viewerId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
}

enum NotificationType {
  FOLLOW
  LIKE
  COMMENT
}

// Gerçek olaylardan (takip/beğeni/yorum) üretilen bildirimler.
// postImageUrl/commentText, okuma yolunun Post'a bağlanmasını gerektirmemek için
// oluşturma anında denormalize edilir (modüller arası döngüsel bağımlılığı önler).
model Notification {
  id           String           @id @default(cuid())
  recipientId  String
  recipient    User             @relation("NotificationsReceived", fields: [recipientId], references: [id], onDelete: Cascade)
  actorId      String
  actor        User             @relation("NotificationsSent", fields: [actorId], references: [id], onDelete: Cascade)
  type         NotificationType
  postId       String?
  postImageUrl String?
  commentText  String?
  read         Boolean          @default(false)
  createdAt    DateTime         @default(now())

  @@index([recipientId, createdAt])
}

// Birebir (1:1) doğrudan mesajlaşma. `key` = iki kullanıcı id'sinin sıralı birleşimi
// ("a:b") — tekilliği garanti eder, find-or-create'i tek sorguya indirir.
model Conversation {
  id                  String   @id @default(cuid())
  key                 String   @unique
  createdAt           DateTime @default(now())
  lastMessageAt       DateTime @default(now())
  // Liste sorgusunda N+1'i önlemek için son mesaj önizlemesi denormalize edilir.
  lastMessageText     String?
  lastMessageSenderId String?

  participants ConversationParticipant[]
  messages     Message[]

  @@index([lastMessageAt])
}

// Kullanıcının bir konuşmadaki üyeliği + okundu durumu (lastReadAt) — okunmamış
// sayısı bununla hesaplanır (lastReadAt'ten sonra, karşı taraftan gelen mesajlar).
model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("UserConversations", fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime     @default(now())
  // Denormalize okunmamış sayacı: yeni mesajda alıcıda +1, okununca 0'a resetlenir.
  unreadCount    Int          @default(0)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("UserMessages", fields: [senderId], references: [id], onDelete: Cascade)
  text           String
  imageUrl       String?
  createdAt      DateTime     @default(now())

  reactions MessageReaction[]

  @@index([conversationId, createdAt, id])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("UserMessageReactions", fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
}

model Highlight {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation("UserHighlights", fields: [userId], references: [id], onDelete: Cascade)
  title     String
  createdAt DateTime        @default(now())
  items     HighlightItem[]

  @@index([userId, createdAt])
}

model HighlightItem {
  id          String    @id @default(cuid())
  highlightId String
  highlight   Highlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)
  /// Kaynak hikaye (silinmiş olabilir) — sadece tekrar eklemeyi engellemek için.
  storyId     String?
  mediaUrl    String
  type        MediaType @default(image)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  @@unique([highlightId, storyId])
  @@index([highlightId, order])
}
