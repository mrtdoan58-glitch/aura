# ============================================================
# Aura — Ortam Değişkenleri (.env)
# ============================================================

# --- Çekirdek ---
NODE_ENV=development                      # development | production | test
APP_URL=http://localhost:3000             # Genel taban URL (OG, sitemap, robots)

# --- Kimlik / veri sürücüsü ---
AUTH_DRIVER=memory                        # memory (DB'siz) | prisma (Postgres)
DATABASE_URL=postgresql://aura:aura@localhost:5432/aura

# --- Redis (üretim rate limiter / cache) ---
REDIS_URL=redis://localhost:6379

# --- Medya depolama (gönderi fotoğrafları — Vercel Blob) ---
# BLOB_READ_WRITE_TOKEN=

# --- E-posta (üretim mailer) ---
# RESEND_API_KEY=
# EMAIL_FROM=no-reply@aura.social

# --- Monitoring (opsiyonel; boşsa devre dışı) ---
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Build ---
# ANALYZE=true                            # bundle analiz raporu
