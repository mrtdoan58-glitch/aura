# Aura — Geliştirme imajı (hot reload)
FROM node:26-alpine
WORKDIR /app
RUN apk add --no-cache libc6-compat openssl
COPY package.json package-lock.json ./
# --ignore-scripts: prisma/schema.prisma henüz kopyalanmadı, postinstall patlar
RUN npm ci --ignore-scripts
COPY . .
RUN npx prisma generate || true
ENV NEXT_TELEMETRY_DISABLED=1
EXPOSE 3000
CMD ["npm", "run", "dev"]
